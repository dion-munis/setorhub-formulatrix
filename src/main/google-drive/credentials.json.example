{
  "_INSTRUKSI": "COPY FILE INI KE credentials.json DAN ISI DENGAN CREDENTIALS ASLI DARI GOOGLE CONSOLE",
  "_CARA_BUAT": [
    "1. Buka https://console.cloud.google.com/",
    "2. Buat project baru: 'Marketing Task Tracker'",
    "3. Enable Google Drive API: https://console.cloud.google.com/apis/library/drive.googleapis.com",
    "4. Buat OAuth2 credentials: https://console.cloud.google.com/apis/credentials",
    "   - Klik '+ Create Credentials' → 'OAuth client ID'",
    "   - Application type: 'Desktop app'",
    "   - Name: 'Marketing Task Tracker'",
    "5. Download JSON dan ganti isi file credentials.json",
    "6. Setup OAuth Consent Screen: https://console.cloud.google.com/apis/credentials/consent",
    "   - User type: External",
    "   - Tambah scope: https://www.googleapis.com/auth/drive.file",
    "   - Tambah test users: email Google yang akan pakai app"
  ],
  "installed": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "client_secret": "YOUR_CLIENT_SECRET",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token",
    "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
    "redirect_uris": ["http://localhost"]
  }
}
