{
  "name": "setorhub",
  "version": "0.1.0",
  "description": "Setor Project Tanpa Drama, Rapor Aman Setiap 6 Bulan - Marketing Design Team, Formulatrix",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Wahid - Formulatrix",
  "license": "UNLICENSED",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "googleapis": "^173.0.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.formulatrix.setorhub",
    "productName": "SetorHub",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
